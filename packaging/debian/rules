#!/usr/bin/make -f
# debian/rules for KDAL - uses CMake via dh_auto_*
#
# The top-level Makefile is a kbuild file for the out-of-tree kernel module.
# Kernel headers (/lib/modules/.../build) are not present in the packaging
# environment. We must pass --buildsystem=cmake explicitly to every dh_auto_*
# call so debhelper never falls back to invoking that Makefile.

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_clean:
	dh_auto_clean --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure --buildsystem=cmake -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr

override_dh_auto_build:
	dh_auto_build --buildsystem=cmake

override_dh_auto_install:
	dh_auto_install --buildsystem=cmake

# Split headers into kdal-dev
override_dh_install:
	dh_install
