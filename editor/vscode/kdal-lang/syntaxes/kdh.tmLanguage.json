{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "KDAL Device Header",
    "scopeName": "source.kdh",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#version-decl"
        },
        {
            "include": "#import-decl"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#access-modes"
        },
        {
            "include": "#signal-keywords"
        },
        {
            "include": "#power-keywords"
        },
        {
            "include": "#blocks"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.kdh",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.kdh",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.kdh",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.kdh",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.kdh",
                    "match": "\\b0x[0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.decimal.kdh",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "version-decl": {
            "patterns": [
                {
                    "name": "keyword.other.version.kdh",
                    "match": "\\bkdal_version\\b"
                }
            ]
        },
        "import-decl": {
            "patterns": [
                {
                    "name": "keyword.control.import.kdh",
                    "match": "\\b(import|as)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.kdh",
                    "match": "\\b(device|class|compatible)\\b"
                },
                {
                    "name": "keyword.other.section.kdh",
                    "match": "\\b(registers|register_map|signals|capabilities|power|power_states|config)\\b"
                },
                {
                    "name": "keyword.other.bitfield.kdh",
                    "match": "\\b(bitfield)\\b"
                },
                {
                    "name": "constant.language.boolean.kdh",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.kdh",
                    "match": "\\b(u8|u16|u32|u64)\\b"
                },
                {
                    "name": "support.type.device-class.kdh",
                    "match": "\\b(uart|i2c|spi|gpio|gpu|npu)\\b"
                }
            ]
        },
        "access-modes": {
            "patterns": [
                {
                    "name": "storage.modifier.access.kdh",
                    "match": "\\b(ro|wo|rw|rc)\\b"
                }
            ]
        },
        "signal-keywords": {
            "patterns": [
                {
                    "name": "keyword.other.signal-direction.kdh",
                    "match": "\\b(in|out|inout)\\b"
                },
                {
                    "name": "keyword.other.signal-trigger.kdh",
                    "match": "\\b(edge|level|completion|timeout)\\b"
                },
                {
                    "name": "constant.language.edge.kdh",
                    "match": "\\b(rising|falling|any|high|low)\\b"
                }
            ]
        },
        "power-keywords": {
            "patterns": [
                {
                    "name": "constant.language.power-state.kdh",
                    "match": "\\b(on|off|suspend)\\b"
                },
                {
                    "name": "keyword.other.power-spec.kdh",
                    "match": "\\b(allowed|forbidden|default)\\b"
                }
            ]
        },
        "blocks": {
            "patterns": [
                {
                    "name": "entity.name.type.device.kdh",
                    "match": "(?<=class\\s)\\w+"
                }
            ]
        }
    }
}