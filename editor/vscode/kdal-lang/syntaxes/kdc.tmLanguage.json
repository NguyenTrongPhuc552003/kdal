{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "KDAL Driver Code",
    "scopeName": "source.kdc",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#version-decl"
        },
        {
            "include": "#import-decl"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#handlers"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.kdc",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.kdc",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.kdc",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.kdc",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.kdc",
                    "match": "\\b0x[0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.decimal.kdc",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "version-decl": {
            "patterns": [
                {
                    "name": "keyword.other.version.kdc",
                    "match": "\\bkdal_version\\b"
                }
            ]
        },
        "import-decl": {
            "patterns": [
                {
                    "name": "keyword.control.import.kdc",
                    "match": "\\b(import|use|as)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.kdc",
                    "match": "\\b(driver|for|if|elif|else|while|return|let)\\b"
                },
                {
                    "name": "keyword.other.handler.kdc",
                    "match": "\\b(on)\\b"
                },
                {
                    "name": "keyword.other.event.kdc",
                    "match": "\\b(probe|remove|read|write|signal|power|timeout)\\b"
                },
                {
                    "name": "keyword.other.backend.kdc",
                    "match": "\\b(backend|config)\\b"
                },
                {
                    "name": "keyword.other.power-state.kdc",
                    "match": "\\b(off|on|suspend)\\b"
                },
                {
                    "name": "keyword.other.loop.kdc",
                    "match": "\\b(in)\\b"
                },
                {
                    "name": "variable.language.input.kdc",
                    "match": "\\b(input)\\b"
                },
                {
                    "name": "constant.language.boolean.kdc",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.kdc",
                    "match": "\\b(u8|u16|u32|u64|i8|i16|i32|i64|bool|str|buf)\\b"
                }
            ]
        },
        "handlers": {
            "patterns": [
                {
                    "name": "entity.name.function.handler.kdc",
                    "match": "(?<=on\\s)(probe|remove|read|write|signal|power|timeout)"
                },
                {
                    "name": "entity.name.type.driver.kdc",
                    "match": "(?<=driver\\s)\\w+"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.kdc",
                    "match": "\\b(reg_read|reg_write|read|write|log|emit|wait|arm|cancel)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.kdc",
                    "match": "[&|~^!<>=+\\-*/%]+"
                }
            ]
        }
    }
}